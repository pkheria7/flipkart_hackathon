# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
venv

# macOS
.DS_Store

# Root-level raw data files (kept local-only)
/*.csv
*.kml

# Track CSVs inside data/ directories
!data/**/*.csv

# Ignore individual oversized processed CSVs
# (use parquet locally or regenerate via pipeline/run_phase1.py)
data/processed/cleaned_violations.csv
data/processed/clustered_violations.csv

# Raw data — never commit
data/raw/

# Secrets / environment
.env
.env.*
*.secret

# Test/type caches
.pytest_cache/
.mypy_cache/

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

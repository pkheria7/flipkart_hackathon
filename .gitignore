# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
venv

# macOS
.DS_Store

# Root-level raw data files (kept local-only)
/*.csv
*.kml

# Track CSVs inside data/ directories
!data/**/*.csv

# Ignore individual oversized processed CSVs
# (use parquet locally or regenerate via pipeline/run_phase1.py)
data/processed/cleaned_violations.csv
data/processed/clustered_violations.csv

# Cache artifacts (demo-critical graph + JSON fallbacks; other cache files stay local)
cache/*
!cache/
!cache/bengaluru_drive_graph.graphml
!cache/*.json

# Raw data — never commit
data/raw/

# Environment / secrets
.env
.env.*
!.env.example
!frontend/.env.example
frontend/.env.local
*.secret

# Test/type caches
.pytest_cache/
.mypy_cache/

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# Agent runtime artifacts (regenerable)
data/outputs/eml/
data/outputs/run_snapshots/
data/outputs/agent_state.json
data/outputs/pending_master_plan.json
data/outputs/approved_master_plan.json
data/outputs/daily_master_plan.json

# SQLite WAL files
data/outputs/*.sqlite-shm
data/outputs/*.sqlite-wal

# Frontend
frontend/node_modules/
frontend/dist/
frontend/frontend/
